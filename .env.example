# Supabase (앱 런타임 — .env.local 에 실제 값 저장)
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-or-publishable-key"

# MCP 전용 — Account > Access Tokens 에서 생성한 PAT (sbp_...)
SUPABASE_ACCESS_TOKEN="sbp_..."
SUPABASE_PROJECT_REF="your-project-ref"

# --- Google OAuth 설정 (수동) ---
# 1. Google Cloud Console → APIs & Services → Credentials
#    OAuth 2.0 Client ID (Web) 생성
#    Authorized redirect URI: https://<project-ref>.supabase.co/auth/v1/callback
# 2. Supabase Dashboard → Authentication → Providers → Google 활성화
#    Client ID / Secret 입력
# 앱 공개 URL (프로덕션 배포 시 설정 — 미설정 시 요청 Host로 자동 감지)
# NEXT_PUBLIC_SITE_URL="https://your-app.vercel.app"
# 3. Supabase Dashboard → Authentication → URL Configuration
#    Redirect URLs (로컬 + 배포 URL 모두 등록):
#      - http://localhost:3000/auth/callback
#      - https://your-app.vercel.app/auth/callback
